{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User account information and preferences.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "favoriteBusinesses": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "email", "role"]
    },
    "Business": {
      "title": "Local Business",
      "description": "Information about a local service or business.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "category": { "type": "string" },
        "description": { "type": "string" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "image": { "type": "string" },
        "rating": { "type": "number" },
        "reviewCount": { "type": "number" },
        "ownerId": { "type": "string" },
        "mapsLink": { "type": "string" },
        "time": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "category", "phone", "address", "status"]
    },
    "News": {
      "title": "Community News",
      "description": "Local news updates and announcements.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "preview": { "type": "string" },
        "content": { "type": "string" },
        "category": { "type": "string" },
        "image": { "type": "string" },
        "authorId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "preview", "category"]
    },
    "Job": {
      "title": "Job Listing",
      "description": "Local job opportunities.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "company": { "type": "string" },
        "type": { "type": "string" },
        "salary": { "type": "string" },
        "description": { "type": "string" },
        "location": { "type": "string" },
        "postedById": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "company", "type"]
    },
    "Application": {
      "title": "Job Application",
      "description": "User applications for job listings.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "jobId": { "type": "string" },
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "coverLetter": { "type": "string" },
        "resumeUrl": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "reviewed", "accepted", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["jobId", "userId", "name", "email", "status"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles accessible by the owner and admins."
    },
    "/businesses/{businessId}": {
      "schema": "Business",
      "description": "Public directory of local services."
    },
    "/news/{newsId}": {
      "schema": "News",
      "description": "Public community news articles."
    },
    "/jobs/{jobId}": {
      "schema": "Job",
      "description": "Public job listings."
    },
    "/applications/{applicationId}": {
      "schema": "Application",
      "description": "Job applications private to the user and admins."
    }
  }
}
