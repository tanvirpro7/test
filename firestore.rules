rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // --- Validation Blueprints ---

    function isValidUser(data) {
      return data.keys().hasAll(['id', 'name', 'email', 'role']) &&
             data.keys().size() <= 8 &&
             data.id == request.auth.uid &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.email is string && data.email.size() <= 100 &&
             data.role in ['user', 'admin'] &&
             data.createdAt == (resource == null ? request.time : existing().createdAt);
    }

    function isValidBusiness(data) {
      return data.keys().hasAll(['name', 'category', 'phone', 'address', 'status']) &&
             data.keys().size() <= 15 &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 200 &&
             data.category is string &&
             data.phone is string && data.phone.size() <= 20 &&
             data.address is string && data.address.size() <= 300 &&
             data.status in ['pending', 'approved', 'rejected'] &&
             (resource == null || data.createdAt == existing().createdAt);
    }

    function isValidNews(data) {
      return data.keys().hasAll(['title', 'preview', 'category']) &&
             data.keys().size() <= 10 &&
             data.title is string && data.title.size() > 0 && data.title.size() <= 300 &&
             data.preview is string && data.preview.size() <= 500 &&
             data.category is string;
    }

    function isValidJob(data) {
      return data.keys().hasAll(['title', 'company', 'type']) &&
             data.keys().size() <= 10 &&
             data.title is string && data.title.size() > 0 && data.title.size() <= 200 &&
             data.company is string && data.company.size() <= 200 &&
             data.type is string;
    }

    function isValidApplication(data) {
      return data.keys().hasAll(['jobId', 'userId', 'name', 'email', 'status']) &&
             data.keys().size() <= 12 &&
             data.jobId is string &&
             data.userId == request.auth.uid &&
             data.name is string && data.name.size() <= 100 &&
             data.email is string && data.email.size() <= 100 &&
             data.status in ['pending', 'reviewed', 'accepted', 'rejected'];
    }

    // --- Matches ---

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isSignedIn() && isValidUser(incoming());
      allow update: if (isOwner(userId) || isAdmin()) && 
                    isValidUser(incoming()) && 
                    incoming().role == existing().role; // Users can't change their own role
      allow delete: if isAdmin();
    }

    match /businesses/{businessId} {
      allow read: if true; // Public directory
      allow create: if isSignedIn() && 
                    isValidBusiness(incoming()) && 
                    incoming().status == 'pending'; // New subs must be pending
      allow update: if (
        (isAdmin() && isValidBusiness(incoming())) ||
        (isSignedIn() && incoming().ownerId == request.auth.uid && 
         isValidBusiness(incoming()) && 
         incoming().diff(existing()).affectedKeys().hasOnly(['name', 'description', 'phone', 'address', 'image', 'updatedAt']))
      );
      allow delete: if isAdmin();
    }

    match /news/{newsId} {
      allow read: if true;
      allow write: if isAdmin() && isValidNews(incoming());
    }

    match /jobs/{jobId} {
      allow read: if true;
      allow write: if isAdmin() && isValidJob(incoming());
    }

    match /applications/{applicationId} {
      allow get: if isSignedIn() && (existing().userId == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && isValidApplication(incoming()) && 
                    exists(/databases/$(database)/documents/jobs/$(incoming().jobId));
      allow update: if isAdmin() && isValidApplication(incoming());
      allow delete: if isAdmin();
    }
    
    match /admins/{userId} {
      allow read: if isSignedIn();
    }
  }
}
